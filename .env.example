# ─────────────────────────────────────────────────────────────
# SamCar Rental V2 — environment variables.
# Copy this file to `.env` and fill in real values.
# Required for `npm run dev` once queries are wired to Prisma:
#   DATABASE_URL, AUTH_SECRET
# Optional until the relevant Phase 4 feature is exercised:
#   RESEND_*, SEMAPHORE_*, TWILIO_*, CLOUDINARY_*
# ─────────────────────────────────────────────────────────────

# ── App ──
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ── Database (Postgres — Neon, Supabase, or local) ──
# Format: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/samcar?sslmode=require"

# ── Auth ──
# Used to sign admin JWTs (via `jose`). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=""
ADMIN_SESSION_COOKIE="samcar_admin_session"
ADMIN_SESSION_MAX_AGE_SECONDS="604800"   # 7 days

# ── Email (Resend) ──
RESEND_API_KEY=""
RESEND_FROM_EMAIL="SamCar Rental <no-reply@samcar.example>"

# ── SMS (Semaphore PH — primary provider for PH numbers) ──
SMS_PROVIDER="semaphore"
SEMAPHORE_API_KEY=""
SEMAPHORE_SENDER_NAME="SAMCAR"

# ── SMS (Twilio — alternate provider) ──
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# ── Cloudinary (private uploads — IDs / proof of billing / car images) ──
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_PRESET_PRIVATE="samcar_private"
CLOUDINARY_UPLOAD_PRESET_PUBLIC="samcar_public"
